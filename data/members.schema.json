{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HypeProof Members",
  "description": "Schema for data/members.json — the SSOT for HypeProof member data",
  "type": "object",
  "required": ["version", "updatedAt", "members"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Last modification date (YYYY-MM-DD)"
    },
    "members": {
      "type": "array",
      "items": { "$ref": "#/definitions/member" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "member": {
      "type": "object",
      "required": ["id", "username", "displayName", "realName", "email", "role", "expertise", "joinDate"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Discord user ID (snowflake). Empty string if unknown."
        },
        "username": {
          "type": "string",
          "description": "Discord username. Empty string if unknown."
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "description": "Display name used across the platform"
        },
        "realName": {
          "type": "string",
          "minLength": 1,
          "description": "Real name (Korean or English)"
        },
        "email": {
          "type": "string",
          "description": "Email address. Empty string if unknown."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "creator", "advisor"],
          "description": "Member role"
        },
        "title": {
          "type": "string",
          "default": "",
          "description": "Job title / position"
        },
        "expertise": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of expertise areas"
        },
        "interests": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of interests"
        },
        "weeklyHours": {
          "type": "integer",
          "minimum": 0,
          "default": 5,
          "description": "Weekly hour commitment"
        },
        "joinDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Join date (YYYY-MM-DD)"
        },
        "articles": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Published article slugs"
        },
        "columnType": {
          "type": "string",
          "enum": ["A", "B", "C"],
          "default": "C",
          "description": "Column type assignment"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "default": "active",
          "description": "Member status"
        },
        "profileImage": {
          "type": "string",
          "description": "Profile image path: /members/{username}.png"
        }
      },
      "additionalProperties": false
    }
  }
}
