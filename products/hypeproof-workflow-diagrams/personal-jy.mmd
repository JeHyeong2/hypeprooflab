        THU["Thu 21:00<br/>Edit review<br/>with TJ"]
        FRI["Fri 20:00<br/>Tech column<br/>writing"]
        SAT["Sat 15:00<br/>Content publish<br/>YouTube upload"]
        SUN["Sun 21:00<br/>Weekly meeting"]
