flowchart TB
    classDef tj fill:#8b4513,stroke:#cd853f,color:#fff,font-weight:bold,font-size:14px
    classDef dim fill:#30363d,stroke:#484f58,color:#8b949e

    subgraph WEEK["🟤 TJ — Weekly Rhythm"]
        MON["Mon 09:00<br/>Review content<br/>backlog"]
        TUE["Tue 20:00<br/>Video editing"]
        WED["Wed 20:00<br/>Video editing<br/>continued"]
        THU["Thu 20:00<br/>Podcast recording<br/>(bi-weekly)"]
        FRI["Fri 19:00<br/>Community ops<br/>planning"]
        SAT["Sat 15:00<br/>Content publish"]
        SUN["Sun 21:00<br/>Weekly meeting"]
    end

    subgraph OUT["Outputs"]
        O1["Edited videos"]
        O2["Podcast episodes"]
        O3["Community ops plan"]
    end

    subgraph KPI["KPIs I Own"]
        K1["Video quality score"]
        K2["Podcast downloads"]
        K3["Content turnaround"]
    end

    MON --> TUE --> WED --> THU --> FRI --> SAT --> SUN
    SUN --> OUT

    class MON,TUE,WED,THU,FRI,SAT,SUN,O1,O2,O3,K1,K2,K3 tj
