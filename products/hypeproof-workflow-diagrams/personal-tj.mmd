flowchart TB
    classDef tj fill:#8b4513,stroke:#cd853f,color:#fff,font-weight:bold,font-size:14px
    classDef dim fill:#30363d,stroke:#484f58,color:#8b949e

    subgraph WEEK["TJ — 주간 리듬"]
        MON["월 09:00<br/>콘텐츠 백로그<br/>리뷰"]
        TUE["화 20:00<br/>영상 편집"]
        WED["수 20:00<br/>영상 편집<br/>계속"]
        THU["목 20:00<br/>팟캐스트 녹음<br/>(격주)"]
        FRI["금 19:00<br/>커뮤니티 운영<br/>기획"]
        SAT["토 15:00<br/>콘텐츠 발행"]
        SUN["일 21:00<br/>주간 미팅"]
    end

    subgraph OUT["산출물"]
        O1["편집된 영상"]
        O2["팟캐스트 에피소드"]
        O3["커뮤니티 운영 플랜"]
    end

    subgraph KPI["내가 담당하는 KPI"]
        K1["영상 품질 점수"]
        K2["팟캐스트 다운로드"]
        K3["콘텐츠 턴어라운드"]
    end

    MON --> TUE --> WED --> THU --> FRI --> SAT --> SUN
    SUN --> OUT

    class MON,TUE,WED,THU,FRI,SAT,SUN,O1,O2,O3,K1,K2,K3 tj
