flowchart TB
    classDef jay fill:#1f6feb,stroke:#388bfd,color:#fff,font-weight:bold,font-size:14px
    classDef dim fill:#30363d,stroke:#484f58,color:#8b949e
    classDef mother fill:#0d1117,stroke:#58a6ff,color:#58a6ff,stroke-width:2px

    subgraph WEEK["Jay — 주간 리듬"]
        MON["월 07:30<br/>성과 리뷰<br/>주간 포커스 설정"]
        TUE["화 08:00<br/>이니셔티브 기획<br/>방향 설정"]
        WED["수 12:00<br/>콘텐츠 검토<br/>& 승인"]
        THU["목 21:00<br/>Mother 파이프라인<br/>점검"]
        FRI["금 19:00<br/>아카데미 준비<br/>파일럿"]
        SAT["토 20:00<br/>주간 미팅<br/>준비"]
        SUN["일 21:00<br/>주간 미팅<br/>+ 회고"]
    end

    subgraph IN["입력"]
        I1["Mother 지표"]
        I2["멤버 산출물"]
        I3["외부 시그널"]
    end

    subgraph OUT["산출물"]
        O1["주간 방향"]
        O2["콘텐츠 승인"]
        O3["Mirror Loop 설정"]
        O4["로드맵 업데이트"]
    end

    subgraph KPI["내가 담당하는 KPI"]
        K1["파이프라인 건강도"]
        K2["멤버 활성화"]
        K3["전체 전략"]
    end

    IN --> MON
    MON --> TUE --> WED --> THU --> FRI --> SAT --> SUN
    SUN --> OUT

    class MON,TUE,WED,THU,FRI,SAT,SUN,O1,O2,O3,O4,K1,K2,K3 jay
    class I1,I2,I3 dim
