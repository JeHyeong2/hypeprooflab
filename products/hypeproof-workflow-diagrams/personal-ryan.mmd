    MON --> TUE --> WED --> THU --> FRI --> SAT --> SUN
    SUN --> OUT

    class MON,TUE,WED,THU,FRI,SAT,SUN,O1,O2,O3,O4,O5,O6,K1,K2,K3,K4,K5 ryan
