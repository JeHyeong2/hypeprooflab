# HypeProof Web — Environment Variables
# Copy this file to .env.local and fill in values.
# Ask Jay (@jayleekr) for credentials.

# ─── Auth (NextAuth.js) ──────────────────────────────────
# Google OAuth (required for login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional — alternative login provider)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth callback URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# Auth secret for JWT signing (required — generate with: openssl rand -base64 32)
AUTH_SECRET=

# ─── Google Sheets — Dashboard 팀 메모 (Service Account) ─
# Spreadsheet 만들고 service account email(...iam.gserviceaccount.com)에 편집 권한 부여,
# 첫 번째 시트 이름은 'Notes', Spreadsheet ID는 URL의 /d/<ID>/edit에서 추출.
GOOGLE_SHEETS_ID=

# 인증은 아래 4가지 방식 중 하나만 채우면 됨 (위에서부터 우선순위):
#
# (방식 1 — 로컬 개발에 가장 편함) JSON key 파일 경로 (web/ 디렉토리 기준 상대경로 OR 절대경로)
#   ※ JSON 파일은 .gitignore에 등록됨 (hypeproof-*.json, /tests/*.json)
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=
#
# (방식 2) JSON 파일 전체를 한 줄로 — 따옴표로 감싸기 (Vercel 등 배포 환경에 적합)
#   GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}'
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# (방식 3) base64 인코딩 — escape 문제 피하고 싶으면
#   bash: cat key.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
#
# (방식 4) email + private_key 분리 — Vercel UI 멀티라인 입력 자연스러움
#   GOOGLE_SERVICE_ACCOUNT_EMAIL=...iam.gserviceaccount.com
#   GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ─── Notion (optional — falls back to data/members.json) ─
NOTION_API_KEY=
NOTION_MEMBERS_DB_ID=
NOTION_PERSONAS_DB_ID=
NOTION_POINTS_DB_ID=

# ─── Supabase (optional — comments, interactions) ────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis / Upstash (optional — rate limiting, cache) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics (optional) ────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA4_ID=
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=
# NEXT_PUBLIC_ANALYTICS_API_KEY=

# ─── CMS API (optional) ─────────────────────────────────
# NEXT_PUBLIC_CMS_API_URL=
# NEXT_PUBLIC_CMS_API_KEY=

# ─── Security ────────────────────────────────────────────
# Random string for hashing viewer IPs (view counting)
IP_HASH_SALT=local-dev-salt

# API secret for credit/points endpoint
CREDIT_API_SECRET=

# ─── System ──────────────────────────────────────────────
NODE_ENV=development
