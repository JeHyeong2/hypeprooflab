# HypeProof Web — Environment Variables
# Copy this file to .env.local and fill in values.
# Ask Jay (@jayleekr) for credentials.

# ─── Auth (NextAuth.js) ──────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth callback URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# ─── Notion (primary data source) ────────────────────────
# Create integration at https://www.notion.so/my-integrations
NOTION_API_KEY=

# Database IDs (found in Notion page URLs)
NOTION_MEMBERS_DB_ID=
NOTION_PERSONAS_DB_ID=
NOTION_POINTS_DB_ID=

# ─── Supabase (comments, interactions) ───────────────────
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis / Upstash (rate limiting, cache) ──────────────
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics (optional for local dev) ──────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA4_ID=
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=
# NEXT_PUBLIC_ANALYTICS_API_KEY=

# ─── CMS API (optional) ─────────────────────────────────
# NEXT_PUBLIC_CMS_API_URL=
# NEXT_PUBLIC_CMS_API_KEY=

# ─── Security ────────────────────────────────────────────
# Random string for hashing viewer IPs (view counting)
IP_HASH_SALT=local-dev-salt

# API secret for credit/points endpoint
CREDIT_API_SECRET=

# ─── System ──────────────────────────────────────────────
NODE_ENV=development
