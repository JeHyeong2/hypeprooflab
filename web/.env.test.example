# Local Supabase test / dev environment.
#
# Supabase CLI v2.76+ uses keys of the form `sb_publishable_*` and
# `sb_secret_*` (the older deterministic JWT keys belong to legacy CLI
# versions). The values below were observed from a fresh `supabase start`
# on CLI 2.76 — they appear to be deterministic across machines, but if
# `npm run db:status` on your machine shows different values, paste
# those instead.
#
# These values only authenticate against the local stack at 127.0.0.1:54321
# and are safe to commit. PRODUCTION keys are completely different and live
# in Vercel env vars (or your team's secret manager).
#
# Copy to .env.test for migration scripts (seed/verify):
#   cp .env.test.example .env.test
#
# Copy to .env.development.local for `next dev` (auto-loaded by Next.js):
#   cp .env.test.example .env.development.local
#   # then append AUTH_SECRET, IP_HASH_SALT — see .env.example for the full list

SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
