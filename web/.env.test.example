# Local Supabase test environment.
# These keys are deterministic across machines for the local stack — they're
# safe to commit because they only authenticate against `supabase start` on
# 127.0.0.1:54321. PRODUCTION keys are completely different and live in
# Vercel env vars.
#
# Copy to .env.test:
#   cp .env.test.example .env.test
#
# Then load before running scripts:
#   set -a; source .env.test; set +a; npm run db:seed

SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
